# Production environment inventory for Dokploy/server.
# Dokploy is the source of truth for real values. GitHub only mirrors the build-time subset.
# GitHub Actions secrets cannot be read back after creation, so recover missing values from Dokploy
# or the upstream provider and then re-save them in GitHub if a build needs them.

# Generate fixed-format values with:
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY => openssl rand -base64 32
# PAYLOAD_SECRET / PREVIEW_SECRET / SOURCE_API_KEY / CALCOM_WEBHOOK_SECRET => openssl rand -hex 32

# Build + runtime
DATABASE_URI=
PAYLOAD_SECRET=
PREVIEW_SECRET=
NEXT_PUBLIC_SERVER_URL=
NEXT_PUBLIC_IS_LIVE=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_S3_HOSTNAME=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_UPLOAD_PREFIX=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=
S3_BUCKET=
SENTRY_AUTH_TOKEN=
RESEND_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_URL=
REDWOOD_USERNAME=
REDWOOD_PASSWORD=

# Runtime only today
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
RESEND_DEFAULT_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOKS_ENDPOINT_SECRET=
SOURCE_API_URL=
SOURCE_API_KEY=
CALCOM_WEBHOOK_SECRET=
REDWOOD_LOGIN_URL=
REDWOOD_DONOR_SEARCH_URL=
REDWOOD_EXPORT_URL=
REDWOOD_IMPORT_URL=
REDWOOD_ACCOUNT_NUMBER=
REDWOOD_ALLOWED_ACCOUNT_NUMBERS=
REDWOOD_DONOR_GROUP=
REDWOOD_IMPORT_PREVIEW_ONLY=
REDWOOD_WORKER_BATCH_LIMIT=
REDWOOD_WORKER_IDLE_SECONDS=
REDWOOD_SCHEDULE_HANDLER_CRON=
EMAIL_TEST_MODE=
EMAIL_TEST_ADDRESS=

# Not production app runtime secrets
# Keep these outside Dokploy app env and outside Docker build secret mounts.
DOCKERHUB_TOKEN=
DOCKERHUB_USERNAME=
RELEASE_PUSH_TOKEN=