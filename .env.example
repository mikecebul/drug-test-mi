# Used to encrypt JWT tokens
# Generate with: openssl rand -hex 24
PAYLOAD_SECRET=payload-secret-here
# Stable Server Action key (base64 AES key, shared across all instances/builds)
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# Generate with: openssl rand -hex 16
PREVIEW_SECRET=preview-secret-here

# base url
NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:3000

# Allow robots to index the site (optional)
NEXT_PUBLIC_IS_LIVE=false

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=google-maps-api-key

# Resend Email
RESEND_DEFAULT_EMAIL=dev@example.dev
RESEND_API_KEY=resend-key-here

# Email safety
# Non-live environments (NEXT_PUBLIC_IS_LIVE=false) redirect notification emails to EMAIL_TEST_ADDRESS.
# EMAIL_TEST_MODE=true forces the same redirect even if the live flag is enabled.
EMAIL_TEST_MODE=true
EMAIL_TEST_ADDRESS=mike@midrugtest.com
# Always removed from non-live notification recipient lists before redirecting.
NON_LIVE_EMAIL_BLOCKLIST=tom@midrugtest.com
EMAIL_HOST=localhost
EMAIL_PORT=1025

# Playwright / Admin E2E
PAYLOAD_ADMIN_AUTOLOGIN_ENABLED=true
PAYLOAD_ADMIN_AUTOLOGIN_EMAIL=e2e.admin.autologin@example.com
PAYLOAD_ADMIN_AUTOLOGIN_PASSWORD=StrongPass123!
# Optional Playwright runner overrides:
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_WORKERS=1

#Turso DB
LOCAL_DATABASE_URL='file:./payload.db'
TURSO_DATABASE_URL=libsql://dbName-username.turso.io
TURSO_AUTH_TOKEN=turso-auth-token

# Mongo DB
DATABASE_URI=mongodb://localhost:27017/cvx-junior-golf

# S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=
NEXT_PUBLIC_S3_HOSTNAME=

# Unsplash API
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=stripe-secret-key
STRIPE_WEBHOOKS_ENDPOINT_SECRET=stripe-webhook-secret

# SEED 
SOURCE_API_URL=http://localhost:3000
SOURCE_API_KEY=

# Glitchtip/Sentry
SENTRY_AUTH_TOKEN=

# Cal.com Webhook
# Prefer CAL_WEBHOOK_SECRET to match the Cal.com API skill. CALCOM_WEBHOOK_SECRET is still supported by the app for existing deployments.
CAL_WEBHOOK_SECRET=your-calcom-webhook-secret-here
# CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret-here

# Redwood / ToxAccess automation
REDWOOD_USERNAME=
REDWOOD_PASSWORD=
REDWOOD_LOGIN_URL=https://toxaccess.redwoodtoxicology.com/Pages/Public/Login.aspx
REDWOOD_DONOR_SEARCH_URL=https://toxaccess.redwoodtoxicology.com/Pages/User/DonorSearch.aspx
REDWOOD_EXPORT_URL=https://toxaccess.redwoodtoxicology.com/Pages/User/ExportDonors.aspx
REDWOOD_IMPORT_URL=https://toxaccess.redwoodtoxicology.com/Pages/User/ImportDonors.aspx
REDWOOD_ACCOUNT_NUMBER=310974
REDWOOD_ALLOWED_ACCOUNT_NUMBERS=310974
# Optional override for ImportDonors "Group" column (falls back to the most common donor group from export)
REDWOOD_DONOR_GROUP=
# Optional safety switch: stop after upload and leave import submit-ready for manual review
REDWOOD_IMPORT_PREVIEW_ONLY=false
# Worker tuning. The worker only processes jobs that are queued explicitly.
REDWOOD_WORKER_BATCH_LIMIT=3
REDWOOD_WORKER_IDLE_SECONDS=2
# Dev-only inline Redwood automation can add local slow-mo here (ms).
REDWOOD_DEV_INLINE_SLOW_MO_MS=200
